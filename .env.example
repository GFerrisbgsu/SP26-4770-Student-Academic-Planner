# ===========================================
# Student Academic Planner - Environment Variables Template
# ===========================================
# Copy this file to .env and fill in actual values
# NEVER commit .env to git - it contains secrets!

# ===========================================
# Database Configuration
# ===========================================
POSTGRES_DB=appdb
POSTGRES_USER=appuser
POSTGRES_PASSWORD=your_secure_password_here

# ===========================================
# Production Server Configuration
# ===========================================
DOMAIN=yourdomain.com

# ===========================================
# pgAdmin Configuration (Docker Compose only)
# ===========================================
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=your_admin_password_here

# ===========================================
# Email Configuration (Resend API)
# ===========================================
# Sign up at https://resend.com
# Generate API key from https://resend.com/api-keys
# Verify your sending domain at https://resend.com/domains
RESEND_API_KEY= re_your_api_key_here
RESEND_FROM_EMAIL=onboarding@resend.dev

# ===========================================
# JWT Configuration
# ===========================================
# Generate a secure random base64 string (at least 32 bytes)
JWT_SECRET=your_base64_encoded_secret_here
JWT_EXPIRATION_MINUTES=60

# ===========================================
# Frontend Configuration
# ===========================================
VITE_API_URL=http://localhost:8080/api
