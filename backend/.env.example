# ==============================================================================
# Smart Academic Calendar - Backend Environment Variables
# ==============================================================================
# Copy this file to `.env` and fill in your actual values
# NEVER commit `.env` to version control - it's in .gitignore
# ==============================================================================

# ==============================================================================
# Database Configuration
# ==============================================================================
# For local development (H2 in-memory), these are not needed.
# For dev/prod profiles, configure these for PostgreSQL:

# Database connection string
# Example: jdbc:postgresql://localhost:5432/smart_calendar
DATASOURCE_URL=jdbc:postgresql://localhost:5432/smart_calendar

# Database driver class (PostgreSQL)
DATASOURCE_DRIVER=org.postgresql.Driver

# Database credentials
DATASOURCE_USERNAME=appuser
DATASOURCE_PASSWORD=apppass

# ==============================================================================
# JWT Configuration
# ==============================================================================
# Generate a secure 32-byte secret and base64 encode it:
# PowerShell: [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Maximum 256 }))
# Linux/Mac: openssl rand -base64 32

# JWT secret key (base64-encoded, minimum 32 bytes)
JWT_SECRET=bG9jYWwtZGV2LXNlY3JldC0zMi1ieXRlcy1sb25nISE=

# JWT token expiration time in minutes (default: 60)
JWT_EXPIRATION_MINUTES=60

# ==============================================================================
# Resend Email API Configuration
# ==============================================================================
# Sign up at https://resend.com to get your API key

# Your Resend API key (starts with "re_")
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_your_actual_api_key_here

# Sender email address
# Development: Use onboarding@resend.dev (no verification needed)
# Production: Use your verified domain (e.g., noreply@smartacademiccalendar.com)
EMAIL_FROM=onboarding@resend.dev

# Enable/disable real email sending (true/false)
# Set to false for pure local testing (emails logged only)
# Set to true to actually send emails via Resend
SEND_REAL_EMAILS=true

# ==============================================================================
# Spring Profile Selection
# ==============================================================================
# Uncomment one of these to override the default profile in application.properties
# SPRING_PROFILES_ACTIVE=local    # H2 in-memory database
# SPRING_PROFILES_ACTIVE=dev      # PostgreSQL with Flyway migrations
# SPRING_PROFILES_ACTIVE=prod     # Production PostgreSQL

# ==============================================================================
# Optional: Database Display Settings
# ==============================================================================
# Show SQL queries in console (true/false)
SPRING_JPA_SHOW_SQL=true

# ==============================================================================
# Quick Start Guide
# ==============================================================================
# 1. Copy this file:
#    cp .env.example .env
#
# 2. Edit .env with your actual values:
#    - Get RESEND_API_KEY from https://resend.com/api-keys
#    - Generate secure JWT_SECRET (see instructions above)
#    - Configure database credentials if using dev/prod profile
#
# 3. Load environment variables:
#    PowerShell: Get-Content .env | ForEach-Object { $name, $value = $_ -split '=', 2; [System.Environment]::SetEnvironmentVariable($name, $value, 'Process') }
#    Linux/Mac: export $(cat .env | xargs)
#
# 4. Run the application:
#    ./mvnw spring-boot:run
#
# ==============================================================================
# Security Notes
# ==============================================================================
# - NEVER commit .env file to version control
# - Use strong, unique values for production
# - Rotate JWT_SECRET regularly in production
# - Keep RESEND_API_KEY confidential
# - Use environment variables in production deployments (not .env files)
# ==============================================================================
